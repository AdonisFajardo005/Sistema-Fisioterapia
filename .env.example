# Variables de Entorno para Producción
# COPIA este archivo a .env y cambia los valores

# Puerto del servidor (Render lo asigna automáticamente)
PORT=3000

# Entorno (production o development)
NODE_ENV=production

# Secreto de sesión (genera uno nuevo para producción)
# Puedes usar: https://generate-secret.vercel.app/64
SESSION_SECRET=tu-secreto-super-seguro-aqui-cambialo

# Duración de la sesión en milisegundos (24 horas por defecto)
SESSION_MAX_AGE=86400000

# URL de la aplicación (para Render será la URL que te dan)
APP_URL=http://localhost:3000

# Base de datos PostgreSQL en producción (Neon, Supabase, etc.)
# Deja vacío para usar SQLite en desarrollo local
DATABASE_URL=
